# Copie este arquivo para .env e preencha localmente.
# Nunca envie .env para o GitHub.

LOL_OWNER_USERNAME=Fernando
LOL_OWNER_PASSWORD=troque-esta-senha
LOL_GUEST_USERNAME=convidado
LOL_GUEST_PASSWORD=troque-esta-senha-de-convidado

PANDASCORE_TOKEN=seu-token-pandascore
